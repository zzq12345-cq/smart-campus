# ===== Server Configuration =====
PORT=3001
NODE_ENV=development

# ===== JWT =====
JWT_SECRET=your-strong-random-secret-at-least-32-chars-here

# ===== CORS (comma-separated origins for production) =====
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ===== Appwrite (Server SDK) =====
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=rainbowrain
APPWRITE_API_KEY=your-appwrite-server-api-key

# Database ID (all tables live in this database)
APPWRITE_DATABASE_ID=mindguard

# ===== AI Chat =====
AI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
AI_API_KEY=your-ai-api-key
AI_MODEL=glm-5v-turbo
AI_TIMEOUT_MS=30000

# ===== PPT Generation =====
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
PPT_OUTLINE_MODEL=glm-5.1
PPT_RENDER_MODEL=glm-5v-turbo

# ===== Rate Limiting =====
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200
# RATE_LIMIT_AI_MAX=20
